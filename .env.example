# ============================================================
# MythicForge VTT — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32

# Max upload file size in MB
MAX_UPLOAD_MB=50

# Log level: debug | info | warn | error
LOG_LEVEL=info

# ── Database ─────────────────────────────────────────────────
# SQLite (local/dev):
DATABASE_URL=file:./data/mythicforge.db

# PostgreSQL (AWS RDS — set this in production):
# DATABASE_URL=postgresql://mythicforge:PASSWORD@your-rds-endpoint.rds.amazonaws.com:5432/mythicforge

# ── Redis (optional — required for multi-instance) ───────────
# Leave blank for single-instance deployments
# AWS ElastiCache:
# REDIS_URL=rediss://your-cluster.cache.amazonaws.com:6379

# ── AWS S3 (optional — leave blank for local disk storage) ───
# AWS_REGION=us-east-1
# S3_BUCKET=mythicforge-production-assets-123456789

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated allowed origins (blank = allow all)
# ALLOWED_ORIGINS=https://vtt.yourdomain.com,https://www.yourdomain.com

# ── Storage Paths (local mode only) ──────────────────────────
ASSETS_DIR=./public/assets
UPLOADS_DIR=./public/uploads
PLUGINS_DIR=./data/plugins
